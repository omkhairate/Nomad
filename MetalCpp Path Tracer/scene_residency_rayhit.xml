<Scene width="1280" height="720" maxRayDepth="32" residencyStrategy="rayHitBudget">
    <CameraPath>
        <!-- Slow dolly that keeps most objects on screen so ray hits accumulate -->
        <Keyframe frame="0" position="0,18,60" lookAt="0,18,0" />
        <Keyframe frame="60" position="-20,18,45" lookAt="0,18,0" />
        <Keyframe frame="180" position="20,18,45" lookAt="0,18,0" />
    </CameraPath>

    <!-- Matte ground plane -->
    <Sphere position="0,-10000,0" radius="10000" albedo="0.8,0.8,0.8" emission="0,0,0" materialType="0" emissionPower="0" />

    <!-- Bright emissive targets that should stay resident once hit -->
    <Sphere position="-35,12,-110" radius="9" albedo="0.0,0.0,0.0" emission="1.0,0.8,0.6" materialType="0" emissionPower="8" />
    <Sphere position="35,16,-115" radius="12" albedo="0.0,0.0,0.0" emission="0.6,0.8,1.0" materialType="0" emissionPower="7" />

    <!-- Cluster of reflective shapes with varying sizes to stress the hit counter -->
    <Sphere position="-10,10,-90" radius="6" albedo="0.9,0.9,0.9" emission="0,0,0" materialType="-1" emissionPower="0" />
    <Sphere position="5,7,-95" radius="4" albedo="0.9,0.9,0.9" emission="0,0,0" materialType="-1" emissionPower="0" />
    <Sphere position="12,18,-105" radius="10" albedo="0.75,0.75,0.75" emission="0,0,0" materialType="-1" emissionPower="0" />

    <!-- A detailed mesh that should become resident when the camera lingers on it -->
    <Mesh
        file="assets/bunny.obj"
        position="0,0,-100"
        scale="10.0"
        albedo="0.9,0.5,0.3"
        emission="0,0,0"
        materialType="0"
        emissionPower="0" />
</Scene>
